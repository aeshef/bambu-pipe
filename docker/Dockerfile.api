FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY packages/bambu_pipe /app/packages/bambu_pipe
COPY apps /app/apps
COPY pyproject.toml /app/pyproject.toml

RUN pip install --no-cache-dir -e "/app/packages/bambu_pipe[api]"

EXPOSE 8080

CMD ["uvicorn", "apps.api.main:create_app", "--factory", "--host", "0.0.0.0", "--port", "8080"]
