# Printer (LAN + Developer Mode)
BAMBU_PIPE_PRINTER_IP=
BAMBU_PIPE_PRINTER_SERIAL=
BAMBU_PIPE_PRINTER_ACCESS_CODE=

# Slicer profiles (run: bash scripts/bootstrap_profiles.sh)
BAMBU_PIPE_PROFILES_DIR=./profiles/bambu_a1
# Optional if auto-discovery fails:
# BAMBU_PIPE_SLICER_BINARY=/Applications/BambuStudio.app/Contents/MacOS/BambuStudio

# Pipeline
BAMBU_PIPE_AUTO_APPROVE=false
BAMBU_PIPE_QUALITY=standard
BAMBU_PIPE_MATERIAL=PLA
BAMBU_PIPE_MAX_UPLOAD_MB=64

# AMS Lite. Physical input number, not zero-based: 1, 2, 3, or 4.
BAMBU_PIPE_USE_AMS=false
BAMBU_PIPE_AMS_SLOT=1

# Text-to-3D stages
# tripo
BAMBU_PIPE_MESH_PROVIDER=tripo
# BAMBU_PIPE_TRIPO_API_KEY=
# BAMBU_PIPE_TRIPO_BASE_URL=https://api.tripo3d.ai/v2/openapi
# BAMBU_PIPE_LLM_API_KEY=

# voice2bambu adapter
# VOICE2BAMBU_TELEGRAM_TOKEN=
# VOICE2BAMBU_ALLOWED_USER_IDS=
# VOICE2BAMBU_BAMBU_PIPE_API_BASE_URL=
# VOICE2BAMBU_TRANSCRIPTION_API_KEY=
# VOICE2BAMBU_TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
# VOICE2BAMBU_TRANSCRIPTION_MODEL=whisper-1
